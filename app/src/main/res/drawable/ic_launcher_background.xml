<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#3247D3"
                android:centerColor="#4F6BFF"
                android:endColor="#6C85FF" />
        </shape>
    </item>
    <item
        android:gravity="top|start"
        android:height="56dp"
        android:width="56dp"
        android:left="10dp"
        android:top="10dp">
        <shape android:shape="oval">
            <solid android:color="#24FFFFFF" />
        </shape>
    </item>
</layer-list>
